{
  "name": "one-file-website",
  "type": "module",
  "scripts": {
    "dev": "vite --port 1111",
    "lint": "eslint merge_later/**/*.js",
    "typecheck": "tsc",
    "build": "npm run lint && npm run typecheck && vite build && mkdir -p dist/merge_later && cp merge_later/media_data.js dist/merge_later/"
  },
  "devDependencies": {
    "vite": "^8.0.16",
    "typescript": "^5.3.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "@eslint/js": "^8.57.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "lucide-react": "^0.344.0",
    "animejs": "^3.2.2",
    "lenis": "^1.1.13"
  }
}
