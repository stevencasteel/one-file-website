{
  "name": "one-file-website",
  "type": "module",
  "scripts": {
    "dev": "vite --port 1111",
    "lint": "eslint merge_later/**/*.js",
    "typecheck": "tsc",
    "check": "tsc && eslint .",
    "build": "npm run check && vite build && mkdir -p dist/merge_later && cp merge_later/media_data.js dist/merge_later/",
    "format": "prettier --write \"merge_later/**/*.js\""
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "animejs": "^3.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "lenis": "^1.1.13",
    "lucide-react": "^0.344.0",
    "prettier": "^3.8.4",
    "typescript": "^5.3.3",
    "vite": "^8.0.16"
  }
}
